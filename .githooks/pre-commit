#!/bin/bash
# Pre-commit hook to check for unstaged files

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo -e "${GREEN}đź”Ť Running pre-commit checks...${NC}"

# Check for unstaged changes
UNSTAGED=$(git diff --name-only)
if [ -n "$UNSTAGED" ]; then
    echo -e "${YELLOW}âš ď¸Ź  Warning: You have unstaged changes:${NC}"
    echo "$UNSTAGED"
    echo ""
    echo -e "${YELLOW}These files will NOT be included in the commit!${NC}"
    echo ""
    read -p "Do you want to add all changes (git add -A) and continue? [y/N] " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        git add -A
        echo -e "${GREEN}âś… All changes staged${NC}"
    else
        echo -e "${RED}âťŚ Commit cancelled. Please stage your changes manually.${NC}"
        exit 1
    fi
fi

# Check for untracked files
UNTRACKED=$(git ls-files --others --exclude-standard)
if [ -n "$UNTRACKED" ]; then
    echo -e "${YELLOW}âš ď¸Ź  Warning: You have untracked files:${NC}"
    echo "$UNTRACKED"
    echo ""
    read -p "Do you want to add these files too? [y/N] " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        git add -A
        echo -e "${GREEN}âś… All files staged${NC}"
    fi
fi

# Verify git user is correct
GIT_USER=$(git config user.name)
GIT_EMAIL=$(git config user.email)

if [ "$GIT_USER" != "utfcmac" ] || [ "$GIT_EMAIL" != "utfcmac@users.noreply.github.com" ]; then
    echo -e "${RED}âťŚ Error: Wrong git user!${NC}"
    echo "Current: $GIT_USER <$GIT_EMAIL>"
    echo "Expected: utfcmac <utfcmac@users.noreply.github.com>"
    echo ""
    read -p "Fix git user configuration? [y/N] " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        git config user.name "utfcmac"
        git config user.email "utfcmac@users.noreply.github.com"
        echo -e "${GREEN}âś… Git user fixed${NC}"
    else
        echo -e "${RED}âťŚ Commit cancelled${NC}"
        exit 1
    fi
fi

# Check commit message format (if commit message is provided)
COMMIT_MSG_FILE=$1
if [ -n "$COMMIT_MSG_FILE" ]; then
    COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

    # Check for conventional commit format
    if ! echo "$COMMIT_MSG" | grep -qE '^(feat|fix|docs|style|refactor|perf|test|chore)(\(.+\))?: .+'; then
        echo -e "${YELLOW}âš ď¸Ź  Warning: Commit message doesn't follow Conventional Commits format${NC}"
        echo "Expected: type(scope): subject"
        echo "Example: feat(api): add new endpoint"
        echo ""
        echo "Your message: $COMMIT_MSG"
        echo ""
        read -p "Continue anyway? [y/N] " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            echo -e "${RED}âťŚ Commit cancelled${NC}"
            exit 1
        fi
    fi
fi

echo -e "${GREEN}âś… Pre-commit checks passed${NC}"
exit 0
