#!/bin/bash
# Pre-commit hook to check for unstaged files

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo -e "${GREEN}🔍 Running pre-commit checks...${NC}"

# Check for unstaged changes
UNSTAGED=$(git diff --name-only)
if [ -n "$UNSTAGED" ]; then
    echo -e "${YELLOW}⚠️  Warning: You have unstaged changes:${NC}"
    echo "$UNSTAGED"
    echo ""
    echo -e "${YELLOW}These files will NOT be included in the commit!${NC}"
    echo ""
    read -p "Do you want to add all changes (git add -A) and continue? [y/N] " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        git add -A
        echo -e "${GREEN}✅ All changes staged${NC}"
    else
        echo -e "${RED}❌ Commit cancelled. Please stage your changes manually.${NC}"
        exit 1
    fi
fi

# Check for untracked files
UNTRACKED=$(git ls-files --others --exclude-standard)
if [ -n "$UNTRACKED" ]; then
    echo -e "${YELLOW}⚠️  Warning: You have untracked files:${NC}"
    echo "$UNTRACKED"
    echo ""
    read -p "Do you want to add these files too? [y/N] " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        git add -A
        echo -e "${GREEN}✅ All files staged${NC}"
    fi
fi

# Verify git user is configured (optional check for maintainers)
# Skip this check for external contributors
EXPECTED_USER="${GIT_HOOK_USER:-}"
EXPECTED_EMAIL="${GIT_HOOK_EMAIL:-}"

if [ -n "$EXPECTED_USER" ] && [ -n "$EXPECTED_EMAIL" ]; then
    GIT_USER=$(git config user.name)
    GIT_EMAIL=$(git config user.email)

    if [ "$GIT_USER" != "$EXPECTED_USER" ] || [ "$GIT_EMAIL" != "$EXPECTED_EMAIL" ]; then
        echo -e "${YELLOW}⚠️  Warning: Git user mismatch${NC}"
        echo "Current: $GIT_USER <$GIT_EMAIL>"
        echo "Expected: $EXPECTED_USER <$EXPECTED_EMAIL>"
        echo ""
        read -p "Fix git user configuration? [y/N] " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            git config user.name "$EXPECTED_USER"
            git config user.email "$EXPECTED_EMAIL"
            echo -e "${GREEN}✅ Git user fixed${NC}"
        fi
    fi
fi

# Check commit message format (if commit message is provided)
COMMIT_MSG_FILE=$1
if [ -n "$COMMIT_MSG_FILE" ]; then
    COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

    # Check for conventional commit format
    if ! echo "$COMMIT_MSG" | grep -qE '^(feat|fix|docs|style|refactor|perf|test|chore)(\(.+\))?: .+'; then
        echo -e "${YELLOW}⚠️  Warning: Commit message doesn't follow Conventional Commits format${NC}"
        echo "Expected: type(scope): subject"
        echo "Example: feat(api): add new endpoint"
        echo ""
        echo "Your message: $COMMIT_MSG"
        echo ""
        read -p "Continue anyway? [y/N] " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            echo -e "${RED}❌ Commit cancelled${NC}"
            exit 1
        fi
    fi
fi

echo -e "${GREEN}✅ Pre-commit checks passed${NC}"
exit 0
